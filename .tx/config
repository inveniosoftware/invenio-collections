# Translate python strings
# 1) Create message catalog:
#    $ pybabel extract -F pyproject.toml -o invenio_collections/translations/messages.pot invenio_collections
#    $ pybabel init -i invenio_collections/translations/messages.pot -d invenio_collections/translations -l <lang>
#    $ pybabel compile -d invenio_collections/translations --use-fuzzy
# 2) Ensure project has been created on Transifex under the inveniosoftware
#    organisation.
# 3) Install the transifex-client
#    $ pip install transifex-client
# 4) Push source (.pot) and translations (.po) to Transifex
#    $ tx push -s -t
# 5) Pull translations for a single language from Transifex
#    $ tx pull -l <lang>
# 6) Pull translations for all languages from Transifex
#    $ tx pull -a

[main]
host = https://app.transifex.com

[invenio.invenio-collections-messages]
file_filter = invenio_collections/translations/<lang>/LC_MESSAGES/messages.po
source_file = invenio_collections/translations/messages.pot
source_lang = en
type = PO

# Translate JavaScript strings
# 1) Navigate to the directory:
#    cd invenio_collections/assets/semantic-ui/translations/invenio_collections
# 2) Install i18n dev dependencies
#    npm install
# 3) Add a new language
#    npm run init_catalog lang <lang>
# 4) Extract translation keys/values
#    $ npm run extract_messages
# 5) Install the transifex-client
#    see: https://developers.transifex.com/docs/cli#transifex-client
# 6) Push source (.pot) and translations (.po) to Transifex
#    Navigate to the root of the invenio_collections repository
#    $ tx push -s -t
# 7) Pull translations for a single language from Transifex
#    $ tx pull -l <lang>
# 8) Pull translations for all languages from Transifex
#    $ tx pull -a
# 9) Compile .po files for all languages
#    $ npm run compile_catalog
# 10) Convert .po file for a single language
#    $ npm run compile_catalog lang <lang>

[o:inveniosoftware:p:invenio:r:invenio-collections-messages-ui]
file_filter = invenio_collections/assets/semantic-ui/translations/invenio_collections/messages/<lang>/messages.po
source_file = invenio_collections/assets/semantic-ui/translations/invenio_collections/translations.pot
source_lang = en
type = PO
